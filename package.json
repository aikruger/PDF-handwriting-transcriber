{
  "name": "obsidian-pdf-transcriber",
  "version": "1.0.0",
  "description": "Transcribe handwritten notes from PDFs using OpenAI's Vision API with audio extraction",
  "main": "main.js",
  "types": "main.ts",
  "scripts": {
    "dev": "esbuild main.ts --bundle --external:obsidian --outfile=main.js --sourcemap --watch",
    "build": "esbuild main.ts --bundle --external:obsidian --outfile=main.js --minify"
  },
  "keywords": [
    "obsidian",
    "pdf",
    "transcription",
    "handwriting",
    "audio",
    "openai",
    "vision"
  ],
  "author": "Jules",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^16.11.6",
    "@typescript-eslint/eslint-plugin": "5.2.0",
    "@typescript-eslint/parser": "5.2.0",
    "builtin-modules": "3.2.0",
    "esbuild": "0.13.12",
    "obsidian": "latest",
    "tslib": "2.4.0",
    "typescript": "4.7.4"
  }
}
